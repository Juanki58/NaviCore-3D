{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Juanki58/NaviCore-3D/docs/manifest.schema.json",
  "title": "NaviCore SIL Fleet Manifest",
  "type": "object",
  "required": ["simulation_fleet"],
  "additionalProperties": false,
  "properties": {
    "simulation_name": {
      "type": "string",
      "description": "Nombre legible de la sesión SIL"
    },
    "tick_rate_hz": {
      "type": "number",
      "minimum": 10,
      "maximum": 500,
      "default": 100,
      "description": "Frecuencia determinista del bucle JSBSim / bridge"
    },
    "origin": {
      "type": "object",
      "required": ["lat_deg", "lon_deg", "alt_m"],
      "additionalProperties": false,
      "properties": {
        "lat_deg": { "type": "number" },
        "lon_deg": { "type": "number" },
        "alt_m": { "type": "number" }
      },
      "description": "Origen NED local para conversión truth → motor gráfico"
    },
    "simulation_fleet": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": { "$ref": "#/$defs/uav_entry" }
    }
  },
  "$defs": {
    "uav_entry": {
      "type": "object",
      "required": [
        "uav_id",
        "truth_port",
        "sensor_port",
        "actuator_port",
        "navicore_telemetry_port",
        "initial_position"
      ],
      "additionalProperties": false,
      "properties": {
        "uav_id": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "truth_port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "description": "UDP SilTruthPacket → Unity/Unreal"
        },
        "sensor_port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "description": "UDP SilSensorPacket → NaviCore SIL"
        },
        "actuator_port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "description": "UDP SilActuatorPacket ← NaviCore"
        },
        "navicore_telemetry_port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "description": "UDP telemetría NaviCore v3 (0x4E43)"
        },
        "jsbsim_script": {
          "type": "string",
          "description": "Ruta opcional al script XML de JSBSim para esta aeronave"
        },
        "model_asset_path": {
          "type": "string",
          "description": "Prefab Unity / Soft Object Unreal"
        },
        "initial_position": {
          "type": "object",
          "required": ["lat_deg", "lon_deg", "alt_m"],
          "additionalProperties": false,
          "properties": {
            "lat_deg": { "type": "number" },
            "lon_deg": { "type": "number" },
            "alt_m": { "type": "number" }
          }
        },
        "sensors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "visible_camera_01",
              "lwir_camera_01",
              "rangefinder_down",
              "rangefinder_forward"
            ]
          },
          "uniqueItems": true
        },
        "control_step": {
          "type": "object",
          "description": "Escalón de mando aislado para banco de pruebas (Paso 3)",
          "additionalProperties": false,
          "properties": {
            "surface": {
              "type": "string",
              "enum": ["throttle", "aileron", "elevator", "rudder"]
            },
            "value": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
            "start_ms": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
